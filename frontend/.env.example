# Backend API Configuration for Production
# Set this to your deployed backend URL when deploying to production
# For local development, leave empty - the Vite proxy will handle API routing
VITE_BACKEND_URL=

# Example for production deployments:
# If backend is deployed to https://api.example.com:
# VITE_BACKEND_URL=https://api.example.com

# If backend is on the same domain (e.g., https://example.com/api):
# VITE_BACKEND_URL=https://example.com
